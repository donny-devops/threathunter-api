# ThreatHunter API — Environment Configuration
# Copy to .env and customize

DATABASE_URL=sqlite+aiosqlite:///./threathunter.db
NVD_API_KEY=           # Optional: Get free key at https://nvd.nist.gov/developers/request-an-api-key
SYNC_ON_STARTUP=true
SYNC_PAGE_SIZE=50
CORS_ORIGINS=["*"]
LOG_LEVEL=INFO
